{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "jest"
    ]
  },
  "include": [
    "src",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
